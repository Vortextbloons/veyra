{
  "name": "veyra",
  "private": true,
  "version": "1.0.0",
  "description": "Local-first AI desktop workspace (Tauri + React)",
  "homepage": "https://github.com/Vortextbloons/veyra#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vortextbloons/veyra.git"
  },
  "bugs": {
    "url": "https://github.com/Vortextbloons/veyra/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "dev:app": "node scripts/dev-app.mjs",
    "dev:full": "npm run tauri -- dev",
    "build": "tsc -b && vite build",
    "build:app": "npm run tauri -- build",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "tauri": "tauri",
    "sync-version": "node scripts/sync-version.mjs",
    "version:check": "node scripts/sync-version.mjs --check",
    "docs:combine": "node scripts/combine-docs.mjs",
    "clean": "powershell -ExecutionPolicy Bypass -File scripts/clean-target.ps1",
    "clean:incremental": "powershell -ExecutionPolicy Bypass -File scripts/clean-target.ps1 -Incremental",
    "screenshots": "node scripts/screenshots.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.2",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
