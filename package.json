{
  "name": "veyra",
  "private": true,
  "version": "0.2.0",
  "description": "Local-first AI desktop workspace (Tauri + React)",
  "homepage": "https://github.com/Vortextbloons/veyra#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vortextbloons/veyra.git"
  },
  "bugs": {
    "url": "https://github.com/Vortextbloons/veyra/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "dev:ui": "vite",
    "dev:app": "node scripts/dev-app.mjs",
    "dev:full": "npm run tauri -- dev",
    "build": "tsc -b && vite build",
    "build:app": "npm run tauri -- build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "sync-version": "node scripts/sync-version.mjs",
    "version:check": "node scripts/sync-version.mjs --check"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "clsx": "^2",
    "lucide-react": "^0.510",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
